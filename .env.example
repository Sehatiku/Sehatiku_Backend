DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<host>:6543/postgres
REDIS_URL=rediss://default:<password>@<host>:6379
JWT_SECRET=<your-jwt-secret>
APP_PORT=9000

# ML inference service (NER + TKPI + XGBoost), deployed on Cloud Run / Railway.
# Consumed by internal/gateway/ml.MLGateway.
ML_API_BASE_URL=https://<cloud-run-url>
ML_API_KEY=<same-key-as-the-ml-service>

# Gemini generative API (Google AI Studio), dipakai internal/gateway/gemini.GeminiGateway
# untuk menyusun narasi ringkasan kesehatan (endpoint summary).
GEMINI_API_KEY=<api-key-google-ai-studio>
GEMINI_MODEL=gemini-2.5-flash

# Eskalasi (acute) — pemicu & anti-banjir. Semua punya default di kode bila kosong.
ALERT_BUDGET=20            # maks eskalasi/nakes/hari sebelum blast WA di-skip (dashboard tetap)
ACUTE_COOLDOWN_HOURS=24    # jeda minimal sebelum eskalasi acute ulang untuk pasien yang sama
ACUTE_GLUCOSE_HIGH=300     # mg/dL — pembacaan ekstrem memicu acute
ACUTE_GLUCOSE_LOW=54       # mg/dL
ACUTE_SYSTOLIC_HIGH=180    # mmHg
ACUTE_DIASTOLIC_HIGH=120   # mmHg
